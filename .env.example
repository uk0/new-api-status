# Database connection (required)
# PostgreSQL:
SQL_DSN=postgresql://user:password@postgres:5432/new-api?sslmode=disable
DB_DRIVER=postgres

# MySQL:
# SQL_DSN=user:password@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true
# DB_DRIVER=mysql

# SQLite:
# SQL_DSN=/data/one-api.db
# DB_DRIVER=sqlite3

# Poll interval in seconds (default: 30)
POLL_INTERVAL=30

# Listen address (default: :8787)
# LISTEN=:8787

# Cloudflare Turnstile (optional)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
